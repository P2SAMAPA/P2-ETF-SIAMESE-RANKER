# ── .env.example ──────────────────────────────────────────────────────────────
# Copy to .env and fill in your values:  cp .env.example .env
# Never commit .env to git.

# HuggingFace token (needs write access to P2SAMAPA org)
HF_TOKEN=hf_YOUR_TOKEN_HERE

# Dataset references (defaults match repo — only change if you fork)
HF_SOURCE_DATASET=P2SAMAPA/fi-etf-macro-signal-master-data
HF_RESULTS_DATASET=P2SAMAPA/p2-etf-siamese-ranker-results

# Model backend: "siamese" or "lgbm"
# "siamese" will auto-fall back to "lgbm" if training exceeds time threshold
MODEL_BACKEND=siamese

# Max seconds before Siamese training falls back to LightGBM (per horizon)
TRAINING_TIME_THRESHOLD=600

# Torch device: "cpu" or "cuda" (CPU is default — model is small enough)
TORCH_DEVICE=cpu
